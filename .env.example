# Growth Strategy Agent - API Keys
# Copy to .env and add your key. Use one or both.

# OpenAI (GPT-4)
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override model (default: claude-sonnet-4-6). Run "node list-models.js" to see options.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# If both are set, OpenAI is used first.
